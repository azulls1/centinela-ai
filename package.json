{
  "name": "vision-aiagentek",
  "version": "1.0.0",
  "description": "Plataforma de IA con visión por computadora para detección de personas, emociones, objetos y acciones en tiempo real",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && uvicorn main:app --reload --host 0.0.0.0 --port 9301",
    "build:web": "cd apps/web && npm run build",
    "install:all": "npm install && cd apps/web && npm install && cd ../api && pip install -r requirements.txt",
    "sb:check": "node --env-file=.env sb-check.mjs",
    "sb:insert": "node --env-file=.env sb-insert.mjs",
    "api:health": "node --env-file=.env api-health.mjs"
  },
  "keywords": [
    "computer-vision",
    "ai",
    "yolo",
    "mediapipe",
    "edge-ai",
    "real-time"
  ],
  "author": "IAGENTEK",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "node-fetch": "^3.3.2"
  }
}
